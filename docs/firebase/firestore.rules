rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function companyPath(companyId) {
      return /databases/$(database)/documents/companies/$(companyId);
    }

    function currentStaffPath(companyId) {
      return /databases/$(database)/documents/companies/$(companyId)/staff/$(request.auth.uid);
    }

    function currentMemberPath(companyId) {
      return /databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid);
    }

    function activeStaff(companyId) {
      return signedIn()
        && (
          (exists(currentStaffPath(companyId))
            && get(currentStaffPath(companyId)).data.status == 'active')
          || (exists(currentMemberPath(companyId))
            && get(currentMemberPath(companyId)).data.status == 'active')
        );
    }

    function activeMember(companyId) {
      return signedIn()
        && exists(currentMemberPath(companyId))
        && get(currentMemberPath(companyId)).data.status == 'active';
    }

    function canAccessAllProjects(companyId) {
      return activeMember(companyId)
        && get(currentMemberPath(companyId)).data.canAccessAllProjects == true;
    }

    function isOwner(companyId) {
      return signedIn()
        && exists(companyPath(companyId))
        && get(companyPath(companyId)).data.ownerUid == request.auth.uid;
    }

    function isOwnerAfter(companyId) {
      return signedIn()
        && getAfter(companyPath(companyId)).data.ownerUid == request.auth.uid;
    }

    function hasPermission(companyId, permissionKey) {
      return activeStaff(companyId)
        && exists(currentStaffPath(companyId))
        && exists(/databases/$(database)/documents/companies/$(companyId)/role_permissions/$(get(currentStaffPath(companyId)).data.roleId))
        && get(/databases/$(database)/documents/companies/$(companyId)/role_permissions/$(get(currentStaffPath(companyId)).data.roleId)).data.permissions[permissionKey] == true;
    }

    function canManageStaff(companyId) {
      return isOwner(companyId) || hasPermission(companyId, 'staff.manage');
    }

    function isAdmin(companyId) {
      return activeStaff(companyId)
        && exists(currentStaffPath(companyId))
        && get(currentStaffPath(companyId)).data.roleId == 'admin';
    }

    function isProjectEntity(entity) {
      return entity in [
        'project_staff_assignments', 'projects',
        'project_agreement_deductions', 'project_milestones', 'work_days',
        'material_purchases', 'material_purchase_items', 'supplier_payments',
        'fuel_entries', 'labor_work_entries', 'labor_payments',
        'labor_advances', 'machine_usage_entries',
        'machine_rental_payments', 'machine_repair_entries',
        'project_estimates', 'project_estimate_items', 'project_bills',
        'project_bill_receipts', 'gst_entries', 'project_expenses'
      ];
    }

    function isAllowedDeltaEntity(entity) {
      return entity in [
        'companies', 'staff_users', 'roles', 'permissions',
        'project_staff_assignments', 'bidder_profiles', 'tenders',
        'tender_expenses', 'tender_documents', 'projects',
        'project_agreement_deductions', 'project_milestones', 'work_days',
        'suppliers', 'material_purchases', 'material_purchase_items',
        'supplier_payments', 'fuel_types', 'fuel_entries', 'laborers',
        'labor_work_entries', 'labor_payments', 'labor_advances', 'machines',
        'machine_usage_entries', 'machine_rental_payments',
        'machine_repair_entries', 'project_estimates',
        'project_estimate_items', 'project_bills', 'project_bill_receipts',
        'gst_entries', 'project_expenses'
      ];
    }

    function deltaShapeIsValid(companyId, deltaId) {
      let data = request.resource.data;
      return data.keys().hasOnly([
          'deltaId', 'companyId', 'entityType', 'entityId', 'operation',
          'payloadJson', 'baseVersion', 'newVersion', 'createdAt',
          'createdByUserId', 'deviceId', 'schemaVersion', 'status', 'projectId'
        ])
        && data.deltaId == deltaId
        && data.companyId == companyId
        && isAllowedDeltaEntity(data.entityType)
        && data.createdByUserId == request.auth.uid
        && data.operation in ['insert', 'update', 'delete']
        && data.status == 'uploaded'
        && data.payloadJson is string
        && data.baseVersion is int
        && data.newVersion is int
        && data.newVersion > data.baseVersion
        && (
          (isProjectEntity(data.entityType)
            && data.keys().hasAll(['projectId'])
            && data.projectId is string)
          || (!isProjectEntity(data.entityType)
            && !data.keys().hasAny(['projectId']))
        );
    }

    function assignedProjectAllows(companyId) {
      let data = request.resource.data;
      let staff = get(currentStaffPath(companyId)).data;
      return !data.keys().hasAny(['projectId'])
        || canAccessAllProjects(companyId)
        || staff.assignedProjectIds.hasAny([data.projectId]);
    }

    function permittedDeltaType(companyId) {
      let entity = request.resource.data.entityType;
      let operation = request.resource.data.operation;
      return (
          entity in ['bidder_profiles', 'tenders', 'tender_expenses', 'tender_documents']
          && hasPermission(companyId,
            operation == 'insert' ? 'tender.create' :
            operation == 'delete' ? 'tender.delete' : 'tender.edit')
        ) || (
          entity == 'projects'
          && hasPermission(companyId,
            operation == 'insert' ? 'project.create' :
            operation == 'delete' ? 'project.delete' : 'project.edit')
        ) || (
          entity in ['project_agreement_deductions', 'project_milestones', 'work_days', 'project_expenses']
          && hasPermission(companyId, 'project.edit')
        ) || (
          entity in ['suppliers', 'material_purchases', 'material_purchase_items', 'supplier_payments']
          && hasPermission(companyId, 'material.entry')
        ) || (
          entity in ['laborers', 'labor_work_entries', 'labor_payments', 'labor_advances']
          && hasPermission(companyId, 'labor.entry')
        ) || (
          entity in ['machines', 'machine_usage_entries', 'machine_rental_payments', 'machine_repair_entries', 'fuel_types', 'fuel_entries']
          && hasPermission(companyId, 'machinery.entry')
        ) || (
          entity in ['project_estimates', 'project_estimate_items', 'project_bills', 'project_bill_receipts']
          && hasPermission(companyId, 'billing.entry')
        ) || (entity == 'gst_entries' && hasPermission(companyId, 'reports.gst'));
    }

    function canReadDeltaEntity(companyId) {
      let entity = resource.data.entityType;
      return (
          entity in ['bidder_profiles', 'tenders', 'tender_expenses', 'tender_documents']
          && (hasPermission(companyId, 'tender.create')
            || hasPermission(companyId, 'tender.edit')
            || hasPermission(companyId, 'tender.delete'))
        ) || (
          entity == 'projects'
          && (hasPermission(companyId, 'project.create')
            || hasPermission(companyId, 'project.edit')
            || hasPermission(companyId, 'project.delete'))
        ) || (
          entity in ['project_agreement_deductions', 'project_milestones', 'work_days', 'project_expenses']
          && hasPermission(companyId, 'project.edit')
        ) || (
          entity in ['suppliers', 'material_purchases', 'material_purchase_items', 'supplier_payments']
          && hasPermission(companyId, 'material.entry')
        ) || (
          entity in ['laborers', 'labor_work_entries', 'labor_payments', 'labor_advances']
          && hasPermission(companyId, 'labor.entry')
        ) || (
          entity in ['machines', 'machine_usage_entries', 'machine_rental_payments', 'machine_repair_entries', 'fuel_types', 'fuel_entries']
          && hasPermission(companyId, 'machinery.entry')
        ) || (
          entity in ['project_estimates', 'project_estimate_items', 'project_bills', 'project_bill_receipts']
          && hasPermission(companyId, 'billing.entry')
        ) || (entity == 'gst_entries' && hasPermission(companyId, 'reports.gst'));
    }

    function assignedProjectAllowsRead(companyId) {
      let staff = get(currentStaffPath(companyId)).data;
      return !resource.data.keys().hasAny(['projectId'])
        || canAccessAllProjects(companyId)
        || staff.assignedProjectIds.hasAny([resource.data.projectId]);
    }

    function canReadDelta(companyId) {
      let isProjectDelta = resource.data.keys().hasAny(['projectId']);
      return activeStaff(companyId)
        && assignedProjectAllowsRead(companyId)
        && (
          canReadDeltaEntity(companyId)
          || (isProjectDelta && hasPermission(companyId, 'project.view_only'))
        );
    }

    function invitePath(companyId, inviteCode) {
      return /databases/$(database)/documents/companies/$(companyId)/invitations/$(inviteCode);
    }

    function invitationEmailMatches(data) {
      return signedIn()
        && request.auth.token.email is string
        && (data.normalizedEmail == request.auth.token.email
          || data.email == request.auth.token.email);
    }

    function matchesInvite(companyId, invitationId) {
      return signedIn()
        && invitationId is string
        && exists(invitePath(companyId, invitationId))
        && get(invitePath(companyId, invitationId)).data.status == 'pending'
        && get(invitePath(companyId, invitationId)).data.expiresAt > request.time
        && invitationEmailMatches(get(invitePath(companyId, invitationId)).data);
    }

    function validInvitedMemberCreate(companyId, uid) {
      let data = request.resource.data;
      let invite = get(invitePath(companyId, data.invitationId)).data;
      return request.auth.uid == uid
        && matchesInvite(companyId, data.invitationId)
        && data.uid == uid
        && data.status == 'active'
        && data.isOwner == false
        && data.normalizedEmail == invite.normalizedEmail
        && data.roleId == invite.roleId
        && data.roleName == invite.roleName
        && data.canAccessAllProjects == invite.canAccessAllProjects
        && data.assignedProjectIds == invite.assignedProjectIds;
    }

    function validOwnMembershipIndex(companyId, uid) {
      let member = getAfter(/databases/$(database)/documents/companies/$(companyId)/members/$(uid)).data;
      let data = request.resource.data;
      return signedIn()
        && request.auth.uid == uid
        && member.uid == uid
        && member.status == 'active'
        && data.keys().hasOnly([
          'companyId', 'companyName', 'roleName', 'roleId', 'status',
          'isOwner', 'canAccessAllProjects', 'assignedProjectIds',
          'lastAccessAt', 'updatedAt'
        ])
        && data.companyId == companyId
        && data.roleId == member.roleId
        && data.roleName == member.roleName
        && data.status == member.status
        && data.isOwner == member.isOwner
        && data.canAccessAllProjects == member.canAccessAllProjects
        && data.assignedProjectIds == member.assignedProjectIds;
    }

    match /app_users/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
          'uid', 'normalizedEmail', 'displayName', 'photoUrl', 'phone',
          'createdAt', 'updatedAt', 'lastLoginAt', 'linkedProviders',
          'defaultCompanyId', 'status'
        ])
        && request.resource.data.uid == uid
        && request.resource.data.status == 'active';
      allow update: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.status == resource.data.status
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'normalizedEmail', 'displayName', 'photoUrl', 'phone', 'updatedAt',
          'lastLoginAt', 'linkedProviders', 'defaultCompanyId'
        ]);
      allow delete: if false;
    }

    match /user_company_memberships/{uid}/companies/{companyId} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create, update: if canManageStaff(companyId)
        || validOwnMembershipIndex(companyId, uid);
      allow delete: if false;
    }

    match /companies/{companyId} {
      allow get, list: if isOwner(companyId) || activeStaff(companyId);
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid;
      allow update: if canManageStaff(companyId);
      allow delete: if false;


      match /members/{uid} {
        allow read: if activeStaff(companyId)
          && (request.auth.uid == uid || canManageStaff(companyId));
        allow create: if canManageStaff(companyId)
          || isOwnerAfter(companyId)
          || validInvitedMemberCreate(companyId, uid);
        allow update: if canManageStaff(companyId)
          || (request.auth.uid == uid
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.roleId == resource.data.roleId
            && request.resource.data.status == resource.data.status
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['lastAccessAt', 'updatedAt']));
        allow delete: if false;
      }

      match /staff/{staffDocId} {
        allow read: if canManageStaff(companyId)
          || (signedIn() && resource.data.firebaseUid == request.auth.uid)
          || matchesInvite(companyId, resource.data.invitationId);
        allow create: if (
            isOwnerAfter(companyId)
            && staffDocId == request.auth.uid
            && request.resource.data.firebaseUid == request.auth.uid
            && request.resource.data.roleId == 'owner'
            && request.resource.data.status == 'active'
          ) || (
            staffDocId == request.auth.uid
            && request.resource.data.firebaseUid == request.auth.uid
            && request.resource.data.status == 'active'
            && matchesInvite(companyId, request.resource.data.invitationId)
          ) || canManageStaff(companyId);
        allow update: if canManageStaff(companyId)
          || (
            matchesInvite(companyId, resource.data.invitationId)
            && resource.data.status == 'invited'
            && request.resource.data.status == 'accepted'
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'acceptedByUid', 'updatedAt'])
          );
        allow delete: if false;
      }

      match /invitations/{inviteCode} {
        allow read: if canManageStaff(companyId)
          || invitationEmailMatches(resource.data);
        allow create: if canManageStaff(companyId);
        allow update: if canManageStaff(companyId)
          || (
            signedIn()
            && resource.data.status == 'pending'
            && invitationEmailMatches(resource.data)
            && request.resource.data.status == 'accepted'
            && request.resource.data.acceptedByUid == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'acceptedByUid', 'acceptedAt'])
          );
        allow delete: if false;
      }

      match /roles/{roleId} {
        allow read: if activeStaff(companyId) || isOwner(companyId);
        allow create: if canManageStaff(companyId) || isOwnerAfter(companyId);
        allow update: if canManageStaff(companyId);
        allow delete: if false;
      }

      match /role_permissions/{roleId} {
        allow read: if activeStaff(companyId) || isOwner(companyId);
        allow create: if canManageStaff(companyId) || isOwnerAfter(companyId);
        allow update: if canManageStaff(companyId);
        allow delete: if false;
      }

      match /devices/{deviceId} {
        allow read: if canManageStaff(companyId)
          || (activeStaff(companyId) && resource.data.firebaseUid == request.auth.uid);
        allow create, update: if signedIn()
          && request.resource.data.firebaseUid == request.auth.uid
          && (activeStaff(companyId) || isOwnerAfter(companyId));
        allow delete: if false;
      }

      // Firestore is a Phase 7 transport log only. No business entity is stored
      // as a normal Firestore document.
      match /sync_deltas/{deltaId} {
        allow read: if isOwner(companyId) || isAdmin(companyId)
          || canAccessAllProjects(companyId)
          || canReadDelta(companyId);
        allow create: if activeStaff(companyId)
          && deltaShapeIsValid(companyId, deltaId)
          && (
            isOwner(companyId)
            || isAdmin(companyId)
            || (permittedDeltaType(companyId) && assignedProjectAllows(companyId))
          );
        allow update: if activeStaff(companyId)
          && resource.data.createdByUserId == request.auth.uid
          && request.resource.data.createdByUserId == resource.data.createdByUserId
          && request.resource.data.companyId == resource.data.companyId
          && request.resource.data.entityType == resource.data.entityType
          && request.resource.data.entityId == resource.data.entityId
          && request.resource.data.deviceId == resource.data.deviceId
          && deltaShapeIsValid(companyId, deltaId)
          && (
            isOwner(companyId)
            || isAdmin(companyId)
            || (permittedDeltaType(companyId) && assignedProjectAllows(companyId))
          );
        allow delete: if false;
      }
    }

    // Enables the constrained collection-group lookup used at login. A user
    // can only discover their own canonical staff metadata document.
    match /{path=**}/staff/{staffDocId} {
      allow read: if signedIn() && resource.data.firebaseUid == request.auth.uid;
    }

    // Everything not explicitly listed above, including tenders, projects,
    // material, labor, machinery, billing, GST and reports, is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
